PUBLIC_INBOX_ADDRESS=contact@example.com
GMAIL_ACCOUNT=agent-inbox@gmail.com

# Download this OAuth client JSON from Google Cloud Console.
GOOGLE_CREDENTIALS_FILE=secrets/google-oauth-client.json
GOOGLE_TOKEN_FILE=secrets/google-token.json

# Full topic path, not just the topic name.
GOOGLE_PUBSUB_TOPIC=projects/YOUR_PROJECT_ID/topics/hermes-contact-inbox
GMAIL_LABEL_IDS=INBOX

SQLITE_PATH=data/bridge.sqlite3

HERMES_WEBHOOK_URL=https://YOUR-HERMES-HOST/webhooks/contact-inbox
HERMES_WEBHOOK_TOKEN=
HERMES_TIMEOUT_SECONDS=10

# Use one of these auth modes for Pub/Sub push.
# Recommended for quick private tunnel setups:
PUBSUB_BEARER_TOKEN=
# Recommended for production Pub/Sub push with OIDC:
PUBSUB_AUDIENCE=

MAX_HISTORY_RESULTS=50
RECOVERY_QUERY=newer_than:3d
